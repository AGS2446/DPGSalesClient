@model DPGSalesClient.Models.QuoteNewModel

@section styles{
    <link href="~/css/CreateEdit.css" rel="stylesheet" />
}
<section class="content-header">
    <h1 class="pull-left">
        Edit Quote
    </h1>
    <a class="btn nav-btn bg-green pull-right" id="btnAddProductEdit">Items</a>

</section>
<section class="content">
    <form asp-action="Edit" asp-controller="Quote" id="qteEditForm">
        <input type="hidden" asp-for="@Model.QuoteID" />
        <input type="hidden" asp-for="@Model.EnquiryID" />
        <input type="hidden" asp-for="@Model.LeadID" />
        <input type="hidden" asp-for="@Model.isDirect" />
        <div class="row">
            <div class="col-md-12">

                <div class="content">
                    <div class="box box-primary">
                        <div class="box-header with-border">
                            <h3 class="box-title">Location</h3>
                        </div>

                        <div class="box-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Division<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.Division" asp-items="@(new SelectList(Model?.DivisionList,"Value","Text"))"></select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Region<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.Region" asp-items="@(new SelectList(Model?.RegionList,"Value","Text"))"></select>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Branch<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.Branch" asp-items="@(new SelectList(Model?.BranchList,"Value","Text"))"></select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Sales Office<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.SalesOffice" readonly>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Plant<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.Plant" asp-items="@(new SelectList(Model?.PlantsList,"Value","Text"))"></select>
                                    </div>
                                </div>
                                <div class="col-md-6">

                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="box box-info">
                        <div class="box-header with-border">
                            <h3 class="box-title">Customer Details</h3>
                        </div>
                        <div class="box-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Customer Code</label>
                                        <input type="text" class="form-control" asp-for="@Model.CustomerCode" readonly>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Customer Name<span class="text-red">*</span></label>
                                        <div class="input-group input-group-sm">
                                            <input type="text" class="form-control" asp-for="@Model.CustomerName" readonly>
                                            <span class="input-group-btn">
                                                <a href="@Url.Action("Customers","Quote")" id="btnCustomerSearch" class="btn btn-info btn-flat" disable><i class="fa fa-search"></i></a>
                                            </span>
                                        </div>
                                    </div>

                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>City<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.City" >
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>State<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.State" >
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Phone Number<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.MobileNumber" >
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Pin Code<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.Pincode" >
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Contact Person<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.ContactPerson" >
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Customer Address<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.CustomerAddress" >
                                    </div>

                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Customer Segment<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.CustomerSegment" asp-items="@(new SelectList(Model?.CustomerSegmentList,"Value","Text"))"></select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Customer Sub Segment<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.CustomerSubSegment" asp-items="@(new SelectList(Model?.CustomerSubSegmentList,"Value","Text"))"></select>
                                    </div>

                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Customer Classification<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.CustomerClassification" asp-items="@(new SelectList(Model?.CustomerClassificationList,"Value","Text"))"></select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Customer Type<span class="text-red">*</span></label>
                                        <select class="form-control select2 @Model.CustomerType" style="width: 100%;" asp-for="@Model.CustomerType" asp-items="@(new SelectList(Model?.CustomerTypeList,"Value","Text"))"></select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="box box-success">
                        <div class="box-header with-border">
                            <h3 class="box-title">Quote Details</h3>
                        </div>
                        <div class="box-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Status</label>
                                        <input type="text" class="form-control" value="OPEN" asp-for="@Model.Status" readonly />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Product Required<span class="text-red">*</span></label>
                                        <select class="form-control select2 @Model.ProdcutRequired" style="width: 100%;" asp-for="@Model.ProdcutRequired" asp-items="@(new SelectList(Model?.ProdcutRequiredList,"Value","Text"))"></select>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Project Name<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.ProjectName">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Probability(%)<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.Probability" asp-items="@(new SelectList(Model?.ProbabilityList,"Value","Text"))"></select>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Contract Value <small>In Lakhs</small><span class="text-red">*</span></label>
                                        <div class="input-group input-group-sm">
                                            <input type="text" class="form-control" asp-for="@Model.ContractValue_IN_LAKHS" readonly>
                                            <span class="input-group-btn">
                                                <a id="btnContractValue" class="btn btn-warning btn-flat"><i class="fa fa-edit"></i></a>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Business Segment<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.BusinessSegment" asp-items="@(new SelectList(Model?.BusinessSegmentList,"Value","Text"))"></select>
                                    </div>
                                </div>
                            </div>
                            @*<div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Quote Validity Date<span class="text-red">*</span></label>
                                        <div class="input-group date">
                                            <div class="input-group-addon">
                                                <i class="fa fa-calendar"></i>
                                            </div>
                                            <input type="text" class="form-control pull-right" asp-for="@Model.QuoteValidityDate">
                                        </div>
                                    </div>
                                </div>
                               
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Document Created Date<span class="text-red">*</span></label>
                                        <div class="input-group date">
                                            <div class="input-group-addon">
                                                <i class="fa fa-calendar"></i>
                                            </div>
                                            <input type="text" class="form-control pull-right" asp-for="@Model.DocumentCreatedDate">
                                        </div>
                                    </div>
                                </div>
                            </div>*@
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Quote Assign To<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.QuoteAssignTo" asp-items="@(new SelectList(Model?.QuoteAssignToList,"Value","Text"))"></select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Quote Due Date<span class="text-red">*</span></label>
                                        <div class="input-group date">
                                            <div class="input-group-addon">
                                                <i class="fa fa-calendar"></i>
                                            </div>
                                            <input type="text" class="form-control pull-right" asp-for="@Model.QuoteMaturityDate">
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Currency<span class="text-red">*</span></label>
                                        <div>
                                            <select class="form-control select2" style="width: 50%;" asp-for="@Model.Currency" asp-items="@(new SelectList(Model?.CurrencyList,"Value","Text"))"></select>
                                            <input type="text" class="form-control" asp-for="@Model.CurrencyValue" style="width: 40%;float: right;top: -34px;position: relative;" placeholder="Currency Value" readonly>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Offer Date</label>
                                        <div class="input-group date">
                                            <div class="input-group-addon">
                                                <i class="fa fa-calendar"></i>
                                            </div>
                                            <input type="text" class="form-control pull-right" asp-for="@Model.QuoteOfferDate">
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Classification 2</label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.Classification2" asp-items="@(new SelectList(Model?.Classification2List,"Value","Text"))"></select>
                                    </div>
                                </div>
                            
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Classification 4<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.Classification4" asp-items="@(new SelectList(Model?.Classification4List,"Value","Text"))"></select>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Tonnage</label>
                                        <input type="text" class="form-control" asp-for="@Model.Tonnage" readonly>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Total Value <small>In Lakhs</small></label>
                                        <input type="text" class="form-control" asp-for="@Model.TotalValue" readonly>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Architect</label>
                                        <input type="text" class="form-control" asp-for="@Model.Architect">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Consultant</label>
                                        <input type="text" class="form-control" asp-for="@Model.Consultant">
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Source Type</label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.SourceType" asp-items="@(new SelectList(Model?.SourceTypeList,"Value","Text"))"></select>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-12">
                                    <div class="form-group">
                                        <label>Description of Quote<span class="text-red">*</span></label>
                                        <textarea class="form-control" asp-for="@Model.QuoteDescription" style="height:60px"></textarea>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!-- /.col -->

        </div>
        <!-- /.row -->
        <div class="row">
            <div class="col-md-11 ">
                <a class="btn btn-default pull-right nav-btn" href="@Url.Action("Details","Quote",new {qteId=Model.QuoteID,status="OPEN" })" style="padding-left:35px;padding-right:35px">Cancel</a>
                <button class="btn btn-success pull-right margin-r-5 nav-btn" type="submit" style="padding-left:35px;padding-right:35px">Save</button>
            </div>
        </div>
    </form>
    <!-- Modal -->
    <div class="modal fade" id="enqCustomersModal" tabindex="-1" role="dialog" aria-labelledby="enqCustomersModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <h5 class="modal-title" id="activityCustomersModalLabel" style="font-weight: 800;color: #00BCD4;">Customers</h5>

                </div>
                <div class="modal-body" style="height:400px;overflow-y:auto">
                    <ul id="ulCustomers" class="CustUl"></ul>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="button" id="btnCustSelect" class="btn btn-primary">Ok</button>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="contractModal" tabindex="-1" role="dialog" aria-labelledby="contractModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <h5 class="modal-title" id="contractModalLabel" style="font-weight: 800;color: #00BCD4;">Contract Value</h5>
                </div>
                <div class="modal-body">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Contract Value <small>In Lakhs</small><span class="text-red">*</span></label>
                            <input type="text" class="form-control" id="txtContractValue">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Remarks <span class="text-red">*</span></label>
                            <textarea type="text" class="form-control" id="txtContracttext" required></textarea>
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="text-align:center">
                    <button type="button" id="btnContractValueSave" style="width:80px" class="btn btn-primary">Save</button>
                    <button type="button" class="btn btn-secondary" style="width:80px" data-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>

</section>

@section scripts{
    <script type="text/javascript" src="~/js/scripts/Quote/CreateEdit.js">
    </script>
}