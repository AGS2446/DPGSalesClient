@model DPGSalesClient.Models.QuoteConvertOrderModel

<style>
    .table>thead>tr>th{
            background-color: #0c5792;
    color: white;
    font-weight:600;
    }
</style>
<section class="content-header">
    <h1>
        Order Products
    </h1>
</section>
<section class="content">
 
    <div class="row" style="margin-bottom:10px">
        <div class="col-md-4 ">
            <a  id="btnBackToEditCreate" class="btn btn-default btn-flat nav-btn pull-left"><i class="fa fa-backward"></i> <span class="hidden-xs">Back</span></a>
        </div>
        <div class="col-md-4 col-lg-offset-4">

            <a href="@Url.Action("AddOrderProduct","Quote", new { BusinesSeg = Model.BusinessSegment,wlstatus= Model.WonLossValue })" class="btn btn-info btn-flat nav-btn pull-right"><i class="fa fa-plus"></i> <span class="hidden-xs">New</span></a>
        </div>

    </div>
    <input type="hidden" asp-for="@Model.QuoteID" />
    <input type="hidden" asp-for="@Model.EnquiryID" />
    <input type="hidden" asp-for="@Model.LeadID" />
    <input type="hidden" asp-for="@Model.QuoteDocumentCreatedDate" />
    <input type="hidden" asp-for="@Model.WonLossValue" />

        <div class="box box-info" >           
            <div class="box-body">          
                <div class="col-xs-12">
                    <table id="example2" class="table table-hover">
                        <thead>
                            <tr>
                                <th>Business Segment</th>
                                <th>Product Seg ID</th>
                                <th>Product Seg</th>
                                <th>Total Quantity</th>
                                <th>Contract Value(In Lakhs)</th>
                                <th>Total Tonnage</th>
                                <th>Turn Over</th>
                                <th>Gross Margin</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model?.OrderProducts != null && Model?.OrderProducts.Count > 0)
                            {
                                @foreach (var item in Model?.OrderProducts)
                                {
                                    if (item.EntityState != OrderProxy.EntityState.Deleted)
                                    {
                                    <tr>
                                        <td>@item.BusinessSegment</td>
                                        <td>@item.ProductSegID</td>
                                        <td>@item.ProductSeg</td>
                                        <td>@item.Quantity</td>
                                        <td>@item.ContractValue</td>
                                        <td>@item.TotalTonnage</td>
                                        <td>@item.TurnoverValue</td>
                                        <td>@item.MarginValue</td>
                                        <td>
                                            <a class="nav-btn" href="@Url.Action("EditOrderProduct", "Quote", new { productId = item.ProductSegID })" style="padding-right:15px;" title="Edit"><i class="fa fa fa-pencil text-primary" style="font-size:18px;font-weight:500;"></i></a>
                                            <a class="nav-btn" href="@Url.Action("DeleteOrderProduct", "Quote", new { productId = item.ProductSegID })" style="padding-right:5px;" title="Delete"><i class="fa fa-trash text-red" style="font-size:18px"></i></a>
                                        </td>
                                    </tr>}
                                }}

                        </tbody>
                    </table>

                </div>
                
            </div>
         
        </div>

 

  

</section>

@section scripts{
    <script type="text/javascript" >
      
        $('#btnBackToEditCreate').click(function (da) {
            debugger;
           
                debugger;
                var url = '@Url.Action("ConvertToOrder","QUOTE")';
                window.location = url + "?strBack=BACK";
           

            return false;
        });
    </script>
}