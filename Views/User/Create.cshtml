@model DPGSalesClient.Models.UserNewModel

@section styles{
    <link href="~/css/CreateEdit.css" rel="stylesheet" />
}

<section class="content-header">
    <h1>
        New User
    </h1>
</section>
<section class="content">
    <form asp-action="Create" asp-controller="User" id="frmUserCreate">
        <div class="box box-primary">
            <div class="box-header with-border">
                <h3 class="box-title">Personal Info</h3>
            </div>
            <div class="box-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Logon Name<span class="text-red">*</span></label>
                            <input type="text" class="form-control" asp-for="@Model.LogonName">
                            <em id="logonname-msg" class="error-class"></em>
                        </div>
                    </div>
                    <div class="col-md-6">
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>First Name<span class="text-red">*</span></label>
                            <input type="text" class="form-control" asp-for="@Model.FirstName">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Last Name<span class="text-red">*</span></label>
                            <input type="text" class="form-control" asp-for="@Model.LastName">
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Mobile<span class="text-red">*</span></label>
                            <input type="text" class="form-control" asp-for="@Model.Mobile">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Email<span class="text-red">*</span></label>
                            <input type="text" class="form-control" asp-for="@Model.Email">
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="box-footer">
            <div class="row">
                <div class="col-md-11 ">
                    <a class="btn btn-default pull-right nav-btn" href="@Url.Action("Index","User")" style="padding-left:35px;padding-right:35px">Cancel</a>
                    <button class="btn btn-success pull-right margin-r-5 nav-btn" style="padding-left:35px;padding-right:35px" type="submit">Save</button>
                </div>
            </div>
        </div>
    </form>

</section>

@section scripts{
    <script type="text/javascript" src="~/js/scripts/User/CreateEdit.js"></script>
}