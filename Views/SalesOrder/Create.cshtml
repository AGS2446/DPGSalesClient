@model DPGSalesClient.Models.SalesOrderNewModel

@section styles{
    <link href="~/css/CreateEdit.css" rel="stylesheet" />
}
<section class="content-header">
    <h1 class="pull-left">
        New Sales Order
    </h1>
    <a class="btn nav-btn bg-green pull-right" id="btnAddItems"> Items</a>

</section>
<section class="content">
    <form asp-action="Create" asp-controller="SalesOrder" id="soCreateForm">
        <input type="hidden" asp-for="@Model.CRMOrderID" />
        <div class="row">
            <div class="col-md-12">
                <div class="content">
                    <div class="box box-primary">
                        <div class="box-header with-border">
                            <h3 class="box-title">Order Info</h3>
                        </div>
                        <div class="box-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Order Type<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.OrderType" asp-items="@(new SelectList(Model.OrderTypeList,"Value","Text"))" ></select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Sales Organization<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.SalesOrg" asp-items="@(new SelectList(Model.SalesOrgList,"Value","Text"))" ></select>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Distbution Channel<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.DistChannel" asp-items="@(new SelectList(Model.DistChannelList,"Value","Text"))" ></select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Division<span class="text-red">*</span></label>
                                        <select  class="form-control select2" style="width: 100%;" asp-for="@Model.Division" asp-items="@(new SelectList(Model.DivisionList,"Value","Text"))"></select>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>PO Number<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.PONumber" maxlength="10">
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>PO Date<span class="text-red">*</span></label>
                                        <div class="input-group date">
                                            <div class="input-group-addon">
                                                <i class="fa fa-calendar"></i>
                                            </div>
                                            <input type="text" class="form-control pull-right" asp-for="@Model.PODate">
                                        </div>
                                    </div>
                                </div>                                
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Condition Type<span class="text-red">*</span></label>
                                        <select type="text" class="form-control" asp-for="@Model.ConditionType" asp-items="@(new SelectList(Model.ConditionTypeList,"Value","Text"))" ></select>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="box box-info">
                        <div class="box-header with-border">
                            <h3 class="box-title">Customer Info</h3>
                        </div>
                        <div class="box-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Customer Code</label>
                                        <input type="text" class="form-control" asp-for="@Model.CustomerCode" readonly>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Customer Name<span class="text-red">*</span></label>
                                        <div class="input-group input-group-sm">
                                            <input type="text" class="form-control" asp-for="@Model.CustomerName" maxlength="50">
                                            <span class="input-group-btn">
                                                <a href="@Url.Action("Customers","SalesOrder")" id="btnCustomerSearch" class="btn btn-info btn-flat"><i class="fa fa-search"></i></a>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div> 
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Ship To Party Code</label>
                                        <input type="text" class="form-control" asp-for="@Model.ShipToPartyCode" readonly>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Ship To Party Name<span class="text-red">*</span></label>
                                        <div class="input-group input-group-sm">
                                            <input type="text" class="form-control" asp-for="@Model.ShipToPartyName" maxlength="50">
                                            <span class="input-group-btn">
                                                <a href="@Url.Action("Customers","SalesOrder")" id="btnShipToPartySearch" class="btn btn-info btn-flat"><i class="fa fa-search"></i></a>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>                       
                        </div>
                    </div>                                
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-11 ">
                <a class="btn btn-default pull-right nav-btn" href="@Url.Action("Index","SalesOrder")" style="padding-left:35px;padding-right:35px">Cancel</a>
                <button class="btn btn-success pull-right margin-r-5 nav-btn" style="padding-left:35px;padding-right:35px">Save</button>
            </div>
        </div>
    </form>
    <!-- Modal -->
    <div class="modal fade" id="enqCustomersModal" tabindex="-1" role="dialog" aria-labelledby="enqCustomersModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="enqCustomersModalLabel">Customers List</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <ul id="ulCustomers" class="CustUl"></ul>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="button" id="btnCustSelect" class="btn btn-primary">Ok</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade" id="enqShipToPartyModal" tabindex="-1" role="dialog" aria-labelledby="enqCustomersModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="enqCustomersModalLabel">Ship TO Party List</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <ul id="ulShipToParty" class="CustUl"></ul>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="button" id="btnShipSelect" class="btn btn-primary">Ok</button>
                </div>
            </div>
        </div>
    </div>  


</section>
@section scripts{
<script type="text/javascript" src="~/js/scripts/SalesOrder/Create.js">

</script>
}

