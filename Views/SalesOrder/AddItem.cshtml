@model DPGSalesClient.Models.SalesOrderItem

<section class="content-header">
    <h1>
        New Item
    </h1>
</section>
<section class="content">
    <form asp-action="AddItem" asp-controller="SalesOrder" method="post" id="frmSalesOrderAddItem">
        <div class="box box-success">
            <div class="box-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Material No<span class="text-red">*</span></label>
                            <div class="input-group input-group-sm">
                                <input type="text" class="form-control" asp-for="@Model.MaterialNo" />
                                <span class="input-group-btn">
                                    <a href="@Url.Action("Materials","SalesOrder")" id="btnMaterialNOSearch" class="btn btn-info btn-flat"><i class="fa fa-search"></i></a>
                                </span>
                             </div>
                            </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Material Desc<span class="text-red">*</span></label>
                            <input type="text" class="form-control" asp-for="@Model.MaterialDesc" readonly />
                        </div>
                    </div>                   
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Plant <span class="text-red">*</span></label>
                            <select class="form-control select2" style="width: 100%;" asp-for="@Model.Plant" asp-items="@(new SelectList(Model.PlantList,"Value","Text"))"></select>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Quantity <span class="text-red">*</span></label>
                            <input type="text" class="form-control" asp-for="@Model.Quantity">
                        </div>
                    </div>                   
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Total Value <span class="text-red">*</span></label>
                            <input type="text" class="form-control" asp-for="@Model.TotalValue">
                        </div>
                    </div>
                    <div class="col-md-6">                       
                    </div>                  
                </div>
            </div>
            <div class="box-footer">
                <div class="row">
                    <div class="col-md-11 ">
                        <a class="btn btn-default pull-right nav-btn" href="@Url.Action("AddItem","SalesOrder")" style="padding-left:35px;padding-right:35px">Cancel</a>
                        <button class="btn btn-success pull-right margin-r-5 nav-btn" style="padding-left:35px;padding-right:35px" type="submit">Add</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
    <div class="modal fade" id="soMaterialModal" tabindex="-1" role="dialog" aria-labelledby="enqCustomersModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="enqCustomersModalLabel">Materials</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <ul id="ulMaterials" class="CustUl"></ul>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="button" id="btnMaterialSelect" class="btn btn-primary">Ok</button>
                </div>
            </div>
        </div>
    </div>
</section>
@section scripts{
    <script type="text/javascript" src="~/js/scripts/SalesOrder/AddItem.js">

    </script>
}
