@model DPGSalesClient.Models.FunnelReportSearchModel
<style>
    .chart-legend ul {
        list-style-type: none;
    }

    .chart-legend li span {
        display: inline-block;
        width: 16px;
        height: 16px;
        margin-right: 8px;
    }

    #divChartContainer {
        width: 80%;
        height: 350px;
        vertical-align: middle;
        align-content: center;
    }
</style>
@section Styles{
    <link rel="stylesheet" href="~/theme-blue/plugins/AMFunnelCharts/export.css" type="text/css" media="all" />
    @*<link href="~/theme-blue/plugins/AMFunnelCharts/export.css" rel="stylesheet" />*@
}
<section class="content-header">
    <h1>
        Sales Funnel Report
    </h1>
</section>
<section class="content">
    <form asp-action="" asp-controller="FunnelReport" id="frmFunnelReport">
        <div class="box box-info">
            <div class="box-body">
                <div class="form-horizontal">
                    <div class="form-group">
                        <div class="col-md-2">
                            <label>Division</label>
                        </div>
                        <div class="col-md-8">
                            <input type="hidden" asp-for="@Model.Division" />
                            <select class="form-control select2" multiple="multiple" id="divisionid" placeholder="Select Division" style="width: 100%;" asp-items="@Model?.DivisionList"></select>
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-info btn-block" id="btnSubmitFunnel" type="button"><i class="fa fa-filter"></i> Go</button>
                        </div>
                    </div>
                    <div class="form-group">
                        <div class="col-md-2">
                            <input type="hidden" asp-for="@Model.Branch" />
                            <label>Branch</label>
                        </div>
                        <div class="col-md-8">
                            <select class="form-control select2" multiple="multiple" id="branchid" data-placement="Select Branch" style="width: 100%;" asp-items="@Model?.BranchList"></select>
                        </div>
                    </div>
                    <div class="form-group">
                        <div class="col-md-2">
                            <input type="hidden" asp-for="@Model.Segment" />
                            <label>Segment</label>
                        </div>
                        <div class="col-md-8">
                            <select class="form-control select2" multiple="multiple" id="segmentid" data-placement="Select Segment" style="width: 100%;" asp-items="@(new SelectList(Model?.SegmentList,"Value","Text"))"></select>
                        </div>
                    </div>
                    <div class="form-group">
                        <div class="col-md-2">
                            <label>Date From</label>
                        </div>
                        <div class="col-md-3">
                            <div class="input-group date">
                                <div class="input-group-addon">
                                    <i class="fa fa-calendar"></i>
                                </div>
                                <input type="text" class="form-control pull-right" asp-for="@Model.DateFrom" autocomplete="off">
                            </div>
                        </div>
                        <div class="col-md-2">
                            <label>Date To</label>
                        </div>
                        <div class="col-md-3">
                            <div class="input-group date">
                                <div class="input-group-addon">
                                    <i class="fa fa-calendar"></i>
                                </div>
                                <input type="text" class="form-control pull-right" asp-for="@Model.DateTo" autocomplete="off">
                            </div>
                        </div>
                        <div class="col-md-2">
                        </div>
                    </div>
                </div>

            </div>
        </div>
        <div class="box-body">
            <div class="form-group">
                <div class="col-md-12">
                    <div id="divChartContainer">
                        <div id="container" style="height: 350px; margin: 0 auto"></div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</section>
@section scripts{

    <script src="~/theme-blue/plugins/AMFunnelCharts/amcharts.js"></script>
    <script src="~/theme-blue/plugins/AMFunnelCharts/export.min.js"></script>
    <script src="~/theme-blue/plugins/AMFunnelCharts/funnel.js"></script>
    <script src="~/theme-blue/plugins/AMFunnelCharts/light.js"></script>

    @*<script src="https://www.amcharts.com/lib/3/amcharts.js"></script>
    <script src="https://www.amcharts.com/lib/3/funnel.js"></script>
    <script src="https://www.amcharts.com/lib/3/plugins/export/export.min.js"></script>
    <script src="https://www.amcharts.com/lib/3/themes/light.js"></script>*@

    <script src="~/js/scripts/FunnelReport/AmChart.js"></script>
    <script>
        $(document).ready(function () {




        })

    </script>


}


