@model DPGSalesClient.Models.FunnelReportSearchModel
<style>
    .chart-legend ul {
        list-style-type: none;
    }

    .chart-legend li span {
        display: inline-block;
        width: 16px;
        height: 16px;
        margin-right: 8px;
    }
</style>
<section class="content-header">
    <h1>
        Sales Funnel Report
    </h1>
</section>
<section class="content">
    <form asp-action="" asp-controller="FunnelReport" id="frmFunnelReport">
        <div class="box box-info">
            <div class="box-body">
                <div class="form-horizontal">
                    <div class="form-group">
                        <div class="col-md-2">
                            <label>Division</label>
                        </div>
                        <div class="col-md-8">
                            <input type="hidden" asp-for="@Model.Division" />
                            <select class="form-control select2" multiple="multiple" id="divisionid" placeholder="Select Division" style="width: 100%;" asp-items="@Model?.DivisionList"></select>
                        </div>
                        <div class="col-md-2">
                            <button class="btn btn-info btn-block" id="btnSubmitFunnel" type="button"><i class="fa fa-filter"></i> Go</button>
                        </div>
                    </div>
                    <div class="form-group">
                        <div class="col-md-2">
                            <input type="hidden" asp-for="@Model.Branch" />
                            <label>Branch</label>
                        </div>
                        <div class="col-md-8">
                            <select class="form-control select2" multiple="multiple" id="branchid" data-placement="Select Branch" style="width: 100%;" asp-items="@Model?.BranchList"></select>
                        </div>
                    </div>
                    <div class="form-group">
                        <div class="col-md-2">
                            <input type="hidden" asp-for="@Model.Segment" />
                            <label>Segment</label>
                        </div>
                        <div class="col-md-8">
                            <select class="form-control select2" multiple="multiple" id="segmentid" data-placement="Select Segment" style="width: 100%;" asp-items="@(new SelectList(Model?.SegmentList,"Value","Text"))"></select>
                        </div>
                    </div>
                    <div class="form-group">
                        <div class="col-md-2">
                            <label>Date From</label>
                        </div>
                        <div class="col-md-3">
                            <div class="input-group date">
                                <div class="input-group-addon">
                                    <i class="fa fa-calendar"></i>
                                </div>
                                <input type="text" class="form-control pull-right" asp-for="@Model.DateFrom" autocomplete="off">
                            </div>
                        </div>
                        <div class="col-md-2">
                            <label>Date To</label>
                        </div>
                        <div class="col-md-3">
                            <div class="input-group date">
                                <div class="input-group-addon">
                                    <i class="fa fa-calendar"></i>
                                </div>
                                <input type="text" class="form-control pull-right" asp-for="@Model.DateTo" autocomplete="off">
                            </div>
                        </div>
                        <div class="col-md-2">
                        </div>
                    </div>                  
                    <div class="form-group">
                        <div class="col-md-12">
                            <div id="divChartContainer">
                                <div id="container" style="min-width: 100px; height: 400px; margin: 0 auto"></div>
                            </div>
                        </div>

                    </div>

                </div>
            </div>
        </div>
    </form>
</section>
@section scripts{
    <script src="~/theme-blue/plugins/FunnelCharts/highcharts.js"></script>
    <script src="~/theme-blue/plugins/FunnelCharts/funnel.js"></script>
    <script src="~/theme-blue/plugins/FunnelCharts/exporting.js"></script>
    <script src="~/theme-blue/plugins/FunnelCharts/export-data.js"></script> 
    <script src="~/js/scripts/FunnelReport/report.js"></script> 
    
    <script>
        $(document).ready(function () {

        


        })

    </script>


}
