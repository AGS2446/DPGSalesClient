@{
    Layout = "";
}
@model DPGSalesClient.Models.ResetPassword

<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>DPG Sales</title>
    <meta content='width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no' name='viewport'>

    <link rel="stylesheet" href="~/theme-blue/bower_components/bootstrap/dist/css/bootstrap.min.css">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="~/theme-blue/bower_components/font-awesome/css/font-awesome.min.css">
    <!-- Ionicons -->
    <link rel="stylesheet" href="~/theme-blue/bower_components/Ionicons/css/ionicons.min.css">
    <!-- Theme style -->
    <link rel="stylesheet" href="~/theme-blue/dist/css/AdminLTE.css">
    <link href="~/css/site.css" rel="stylesheet" />
    <!-- HTML5 Shim and Respond.js IE8 support of HTML5 elements and media queries -->
    <!-- WARNING: Respond.js doesn't work if you view the page via file:// -->
    <!--[if lt IE 9]>
      <script src="https://oss.maxcdn.com/libs/html5shiv/3.7.0/html5shiv.js"></script>
      <script src="https://oss.maxcdn.com/libs/respond.js/1.3.0/respond.min.js"></script>
    <![endif]-->

   
</head>
<body>
    <div id="initialload">
        <div class="bg-black-opacity" style="z-index:1200; position:fixed;width:100%;height:100%;"></div>
        <div class="progress progress-sm progress-striped  active" style="margin:0px;height:0px">
            <div class="progress-bar progress-bar-info" style="z-index: 1202; position: fixed; width: 100%;height:3px;"></div>
        </div>
        <div class="text-center text-white" style="z-index: 1201; position: fixed; background: #EDEDED; color: #3B3B3B; width: 160px; height: 124px; left: 50%; top: 50%; margin-left: -80px; margin-top: -62px; border-radius: 5px; padding: 40px;min-height:124px">
            <p class="m-n">
                <i class="fa fa-3x fa-spinner fa-pulse fa-fw" style="color:#0889ea"></i>
                @*<span class="h2 font-thin">Loading...</span>*@
            </p>
        </div>
    </div>
    <div class="col-md-8 hidden-xs login-left">
        <img src="~/images/voltas-logo.png" class="logo-m" />
        <div class="Login-disp-box">           
            <label class="lbl-left-H1">Welcome To <span>DPG SALES</span></label><br />
            <label class="lbl-left-H2">Login to access your account</label>
        </div>
    </div>
    <div class="col-md-4 col-sm-12 col-xs-12 login-right">
        <div class="login-box" style="padding-top:100px;padding-bottom:80px">
            <div class="header">
                <span style="color:white;font-weight:bold;font-size:24px;">Reset Password</span><br />
                <span style="color:white;font-weight:normal;font-size:12px;">Enter your code which you got through SMS and Email.</span>
            </div>
            <div class="body">
                <form class="MyForm" method="post" asp-action="ResetPassword" asp-controller="Auth" id="resetForm">
                    <input type="hidden" asp-for="UserID" />
                    <div class="form-group">
                        <input type="text" placeholder="Code" asp-for="@Model.Code" />
                    </div>
                    <div class="form-group">
                        <input type="password" placeholder="Password" asp-for="@Model.Password" />
                    </div>
                    <div class="form-group">
                        <input type="password" placeholder="ConfirmPassword" asp-for="@Model.ConfirmPassword" />
                    </div>

                    <div style="padding-top:20PX;">
                        <div class="col-md-7 col-sm-12">
                            <div class="form-group">
                                <input type="submit" class="btn btn-default nav-btn" style="width:100%;margin-left:-20px;" value="Reset Password" />
                            </div>

                        </div>
                        <div class="col-md-5 col-sm-12" style="padding-top:15px">
                            <a class="hover_ul" style="color:white;margin-left:15px;margin-top:15px;font-weight:100;text-decoration:none" href="@Url.Action("Login")">Cancel</a>
                        </div>
                    </div>


                </form>
            </div>

        </div>

    </div>


    <!-- jQuery 3 -->
    <script src="~/theme-blue/bower_components/jquery/dist/jquery.min.js"></script>
    <!-- Bootstrap 3.3.7 -->
    <script src="~/theme-blue/bower_components/bootstrap/dist/js/bootstrap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.17.0/jquery.validate.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.17.0/additional-methods.js"></script>

    <script type="text/javascript">

        jQuery.validator.addMethod("ValidPassword", function (value, element) {
            return this.optional(element) || /^.*(?=.{8,})(?=.*\d)(?=.*[A-Z])(?=.*[a-z])(?=.*[@@#$%&]).*$/i.test(value);
        }, "Please provide correct password");

        $("#initialload").hide();
        $("#resetForm").validate({
            errorClass: "error-class",
            rules: {

                Code: {
                    required: true
                },
                Password: {
                    required: true,
                    minlength: 5,
                    ValidPassword: true
                },
                ConfirmPassword: {
                    equalTo: "#Password"
                }
            },
            messages: {

                Code: {
                    required: "Please provide code received from sms / email"
                },
                Password: {
                    required: "Please provide password",
                    minlength: "Password length should be 5 or more characters."
                },
                ConfirmPassword: {
                    equalTo: "Password and Confirm password are mismatched"
                }
            },
            submitHandler: function (form) {
                // do other things for a valid form
                form.submit();
            },
            errorPlacement: function (error, element) {
                if (element.parent('.input-group').length) {
                    error.insertAfter(element.parent());
                } else {
                    error.insertAfter(element);
                }
            },
            invalidHandler: function (event, validator) {
                // 'this' refers to the form
                $("#initialload").hide();
            }
        });
    </script>

    @if (TempData["PopupViewModel"] != null)
    {
        @Html.Partial("Popup", TempData["PopupViewModel"])
    }
</body>
</html>
