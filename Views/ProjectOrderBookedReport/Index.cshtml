<style>
    .bar-legend {
        padding-left: 0px;
    }

    .chart-legend ul {
        list-style-type: none;
    }

    .chart-legend li span {
        display: inline-block;
        width: 16px;
        height: 16px;
        margin-right: 8px;
    }
</style>


<section class="content-header">
    <h1>Project Order Booked Report</h1>
</section>
<section class="content">
    <div class="row">
        <div class="col-sm-12 col-sm-9">
            <div id="divChartContainer">
                <canvas id="barChart" style="height:250px"></canvas>
            </div>
        </div>
        <div class="col-sm-12 col-sm-3">
            <div class="box box-primary box-solid">
                <div class="box-header">
                    <h3 class="box-title"> <i class="fa fa-filter"></i> Filter</h3>
                </div>
                <div class="box-body">
                    <div class="form-group">
                        <div class="input-group">
                            <div class="input-group-addon">
                                <i class="fa fa-calendar"></i>
                            </div>
                            <input id="startDate" type="text" class="form-control pull-right" name="startDate" value="@ViewBag.StartDate">
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Division:</label>
                        <select name="division" id="division" asp-items="@ViewBag.Divisions" class="form-control select2" multiple="multiple" data-placeholder="Search Division"></select>
                    </div>
                    <div class="form-group">
                        <label>Branch</label>
                        <select name="branch" id="branch" asp-items="@ViewBag.Branches" class="form-control select2" multiple="multiple" data-placeholder="Search Branch"></select>
                    </div>
                    <div class="form-group">
                        <button class="btn btn-info btn-block" name="filter" id="filter"><i class="fa fa-bar-chart-o"></i> GO</button>
                    </div>
                </div>
            </div>
            <div>
                <div id="bar_legend" class="chart-legend"></div>
            </div>
        </div>
    </div>
</section>

@section scripts{
    <script src="~/theme-blue/bower_components/Chart.js/Chart.js"></script>
    <!-- Page script -->
    <script src="~/js/scripts/ProjectOrderBookedReport/ProjectOrderBookedReport.js"></script>
}