                </div>*@
            <div class="col-md-3 col-lg-offset-9">
                <a href="@Url.Action("Upload","OrderUpload")" class="btn btn-primary btn-flat nav-btn pull-right" style="margin-left:5px;"><i class="fa fa-plus"></i> <span class="hidden-xs"> Upload</span></a>                
            </div>
        </div>
    </form>
    <div class="row">
        <div class="col-xs-12">
            <label class="text-success">@ViewBag.Result</label>
            <label class="text-danger">@ViewBag.Error</label>
        </div>
    </div>  

</section>

@section scripts{
    <script type="text/javascript">
        $('#example2').DataTable({
            'paging': true,
            'lengthChange': false,
            'searching': false,
            'ordering': true,
            'info': true,
            'autoWidth': false,
            'pageLength': 8,
            'order': [[1, 'desc']]
        });

        $('#btnSearch').click(function () {
            var input = $("<input>").attr("type", "hidden").attr("name", "strKey").val($('#SearchKey').val());
            if ($('#SearchKey').val() != null && $('#SearchKey').val() != "") {
                $('#searchForm').append(input);
                $('#searchForm').submit();
            } else {

                alert('Please provide Enquiry Id or Customer Name or Status');
                return false;
            }
        });
    </script>
}