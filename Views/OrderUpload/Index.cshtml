        Order Upload
    </h1>   
</section>
<section class="content">
    <form asp-controller="OrderUpload" method="post">
        <div class="row">
            @*<div class="col-md-4 ">
                    <form asp-action="Search" asp-controller="Enquiry" method="post" id="searchForm">
                        <div class="form-group">
                            <div class="input-group input-group-sm">
                                <input type="text" class="form-control" id="SearchKey" placeholder="Enquiry ID or Customer Name or Status" value="@Model?.SearchKey" >
                                <span class="input-group-btn">
