    <script src="~/theme-blue/dist/js/adminlte.js"></script>

    @if (TempData["PopupViewModel"] != null)
    {
        var popupViewModel = TempData.GetObjectFromJson<PopupViewModel>("PopupViewModel");
        @Html.Partial("Popup", popupViewModel)
    }

    <script type="text/javascript">
        $(document).ready(function () {
            $('#ddlUserRole').change(function () {
                debugger;
                $.post("@Url.Action("ChangeRole", "Auth")", { role: $('#ddlUserRole').val() });

            });


            $("#initialload").hide();
            $('#closeAlertMaster').click(function () {
                $("#alertMaster").hide().animate({ top: "0%" }, 10);;

            });
            $('#okAlertMaster').click(function () {
                $("#alertMaster").hide().animate({ top: "0%" }, 10);;
            });
        });

        $(document).on('click', 'nav ul li ul li a', function (e) {
            $("#initialload").show();
        });

        $(document).on('click', '.nav-btn', function (e) {
            $("#initialload").show();
        });

        $(document).on('click', '#closePopupNotificationView', function (e) {
            $("#_PopupNotificationView").hide();
        });

        $(document).on('click', '#btnSignout', function (e) {

                    //$("#alertMsgMaster").html("Please Select any Category");
            //$("#alertMaster").show().animate({ top: "50%" }, 400);

            $.confirm({
                title: 'Confirmation',
                content: 'Are you sure you want to SignOut?',
                buttons: {
                    Yes: {
                        text: 'Yes',
                        btnClass: 'btn-blue',                       
                        action: function () {
                            window.location.href = '@Url.Action("Login", "Auth")';
                        }
                    },
                    No: function () {
                       
                    },
                    
                }
            });


            @*var perm = confirm('Are you sure you want to SignOut?')
            if (perm == true) {
                debugger;

                window.location.href = '@Url.Action("Login", "Auth")';
            }*@


                    return false;
        });
        //iCheck for checkbox and radio inputs
        $('input[type="checkbox"].minimal, input[type="radio"].minimal').iCheck({
            checkboxClass: 'icheckbox_minimal-blue',
            radioClass: 'iradio_minimal-blue'
        })
        //Red color scheme for iCheck
        $('input[type="checkbox"].minimal-red, input[type="radio"].minimal-red').iCheck({
            checkboxClass: 'icheckbox_minimal-red',
            radioClass: 'iradio_minimal-red'
        })
        //Flat red color scheme for iCheck
        $('input[type="checkbox"].flat-red, input[type="radio"].flat-red').iCheck({
            checkboxClass: 'icheckbox_flat-green',
            radioClass: 'iradio_flat-green'
        })


        function AlertPopup(message) {
            $.alert({
                title: 'Alert!',
                content: message,
                buttons: {
                    Ok: {
                        text: 'Ok',
                        btnClass: 'btn-blue',
                        action: function () {

                        }
                    }

                }
            });
        }
    </script>

    @RenderSection("scripts", required: false)
</body>
</html>
