    <style>
        .error-class {
            color: red;
            z-index: 0;
            position: relative;
            display: block;
            text-align: left;
        }

        .disable {
            pointer-events: none;
            cursor: not-allowed;
            opacity: 0.5;
        }

            .disable > i {
                color: #808080 !important;
            }

        .bg-black-opacity {
            background-color: rgba(32, 43, 54, 0.5);
        }
