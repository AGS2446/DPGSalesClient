    <script src="~/theme-blue/bower_components/bootstrap-daterangepicker/daterangepicker.js"></script>
    <!-- datepicker -->
    <script src="~/theme-blue/bower_components/bootstrap-datepicker/dist/js/bootstrap-datepicker.min.js"></script>
    <script src="~/theme-blue/bower_components/datatables.net-bs/js/date-uk.js"></script>
    <!-- Slimscroll -->
    <script src="~/theme-blue/bower_components/jquery-slimscroll/jquery.slimscroll.min.js"></script>
