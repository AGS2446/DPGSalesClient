</head>
<body class="hold-transition skin-blue sidebar-mini fixed">
    <div id="initialload">
        <div class="bg-black-opacity" style="z-index:1200; position:fixed;width:100%;height:100%;"></div>
        <div class="progress progress-sm progress-striped  active" style="margin:0px;height:0px">
            <div class="progress-bar progress-bar-info" style="z-index: 1202; position: fixed; width: 100%;height:3px;"></div>
        </div>
        <div class="text-center text-white" style="z-index: 1201; position: fixed; background: #EDEDED; color: #3B3B3B; width: 160px; height: 124px; left: 50%; top: 50%; margin-left: -80px; margin-top: -62px; border-radius: 5px; padding: 40px;min-height:124px">
            <p class="m-n">
                <i class="fa fa-3x fa-spinner fa-pulse fa-fw" style="color:#0889ea"></i>
                @*<span class="h2 font-thin">Loading...</span>*@
            </p>
        </div>
    </div>

    <div id="alertMaster" class="bg-white " style="display: none; z-index: 1201; position: fixed; width: 420px; height: 180px; left: 50%; margin-left: -210px; margin-top: -90px; border-radius: 0px;border: 1px solid #2e78a4;border-top: none;background-color:#eae8e8 ">
        <button id="closeAlertMaster" type="button" class="btn btn-link pull-right "><i class="fa fa-times-circle text-white"></i></button>
        <div class="block " style="margin-top: -10px;height: 40px;background-color:#2e78a4">
            <p class="text-white h4" style="padding:10px 0 0 10px"> DPG Sales</p>
        </div>
        <div class="block" style="min-height:84px;margin-top: -10px;">
            <p id="alertMsgMaster" class="text-dark-dker h5"></p>
        </div>
        <div class="block" style="margin-top: -10px;text-align:center">
            <button id="okAlertMaster" type="button" class="btn btn-sm btn-primary"><i class="fa fa-check"></i> OK</button>
        </div>
    </div>

    <div class="wrapper">
        <header class="main-header">
            <!-- Logo -->
            <a href="#" class="logo">
                <!-- Add the class icon to your logo image or logo icon to add the margining -->
                <img class="logo-lg" src="~/images/temp/logo.png" style="width:210px;height:48px;margin-left:-10px;margin-top:-5px" />
                <img class="logo-mini" src="~/images/temp/logo.png" style="width:60px;height:48px;margin-left:-10px;margin-top:-5px" />
            </a>
            <!-- Header Navbar: style can be found in header.less -->
            <nav class="navbar navbar-static-top">
                <!-- Sidebar toggle button-->
                <a href="#" class="sidebar-toggle" data-toggle="push-menu" role="button">
                    <span class="sr-only">Toggle navigation</span>
                </a>
                <div class="navbar-custom-menu">
                    <ul class="nav navbar-nav">
                        <!-- Tasks: style can be found in dropdown.less -->
                        <li class="dropdown tasks-menu">
                            <a style="color:white;padding-top:15px"> <i class="fa fa-edit margin-r-5"></i><span class="hidden-xs ">Help</span></a>
                        </li>
                        <li>
                            <a id="btnSignout" href="@Url.Action("Login","Auth")" style="color:white;padding-top:15px"> <i class="fa fa-sign-out margin-r-5"></i><span class="hidden-xs ">Sign Out</span></a>
                        </li>
                        <!-- User Account: style can be found in dropdown.less -->
                        @*<li class="dropdown user user-menu">
                                <a href="#" class="dropdown-toggle" data-toggle="dropdown">
                                    <img src="~/theme-blue/dist/img/user2-160x160.jpg" class="user-image" alt="User Image">
                                    <span class="hidden-xs">Alexander Pierce</span>
                                </a>
                                <ul class="dropdown-menu">
                                    <!-- User image -->
                                    <li class="user-header">
                                        <img src="~/theme-blue/dist/img/user2-160x160.jpg" class="img-circle" alt="User Image">
                                        <p>
                                            Alexander Pierce - Web Developer
                                            <small>Member since Nov. 2012</small>
                                        </p>
                                    </li>
                                    <!-- Menu Body -->
                                    <li class="user-body">
                                        <div class="row">
                                            <div class="col-xs-4 text-center">
                                                <a href="#">Followers</a>
                                            </div>
                                            <div class="col-xs-4 text-center">
                                                <a href="#">Sales</a>
                                            </div>
                                            <div class="col-xs-4 text-center">
                                                <a href="#">Friends</a>
                                            </div>
                                        </div>
                                        <!-- /.row -->
                                    </li>
                                    <!-- Menu Footer-->
                                    <li class="user-footer">
                                        <div class="pull-left">
                                            <a href="#" class="btn btn-default btn-flat">Profile</a>
                                        </div>
                                        <div class="pull-right">
                                            <a href="#" class="btn btn-default btn-flat">Sign out</a>
                                        </div>
                                    </li>
                                </ul>
                            </li>*@
                        <!-- Control Sidebar Toggle Button -->
                        <li>

                        </li>
                    </ul>
                </div>
            </nav>
        </header>
        <!-- Left side column. contains the logo and sidebar -->
        <aside class="main-sidebar">
            <!-- sidebar: style can be found in sidebar.less -->
            <section class="sidebar">

                @await Component.InvokeAsync("LoggedUser")

                <!-- Sidebar user panel -->
                @*<div class="user-panel">
                        <div class="pull-left image">
                            <img src="~/theme-blue/dist/img/user2-160x160.jpg" class="img-circle" alt="User Image">
                        </div>
                        <div class="pull-left info">
                         Mr.
                            @*<br />
                            <div class="col-md-12 no-padding">
                                <select class="dropdown" style="width:200%;background-color:transparent;border:none;border-bottom:#3c8dbc;border-bottom-width:1px;border-bottom-style:solid;color:white;" id="ddlUserRole">
                                    <option value="1">Administrator</option>
                                    <option value="2">Manager</option>
                                </select>
                            </div>
                        </div>

                    </div>*@


                <!-- sidebar menu: : style can be found in sidebar.less -->
                @await Component.InvokeAsync("Navigation")
            </section>
            <!-- /.sidebar -->
        </aside>
        <!-- Content Wrapper. Contains page content -->
        <div class="content-wrapper">
            <!-- Content Header (Page header) -->
            <!-- Main content -->
            <section class="content">
                @RenderBody()
            </section>
            <!-- /.content -->
        </div>
        <!-- /.content-wrapper -->
        <footer class="main-footer">
            <div class="pull-right hidden-xs">
                <b>Version</b> 1.0.0
            </div>
            <strong>Copyright &copy; 2017 <a href="http://adventglobal.com/">Advent Global</a>.</strong> All rights
