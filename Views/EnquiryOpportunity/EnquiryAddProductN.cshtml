@model DPGSalesClient.Models.EnquiryProduct

<section class="content-header">
    <h1>
        New Product
    </h1>

</section>
<section class="content">

    <form asp-action="EnquiryAddProductN" asp-controller="EnquiryOpportunity" method="post" id="frmAddProduct">

        <div class="box box-success">

            <div class="box-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>BusinessSegment<span class="text-red">*</span></label>
                            <input type="text" class="form-control" asp-for="@Model.BusinessSegment" readonly />
                            <input type="hidden" asp-for="@Model.Division" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Product Segment <span class="text-red">*</span></label>
                            <select class="form-control select2" style="width: 100%;" asp-for="@Model.ProductSeg" asp-items="@Model.ProductList">
                            </select>

                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Total Quantity <span class="text-red">*</span></label>
                            <input type="text" class="form-control" asp-for="@Model.Quantity">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Total Value (In Lakhs)<span class="text-red">*</span></label>
                            <input type="text" class="form-control" asp-for="@Model.TotalValue">
                        </div>
                    </div>

                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Total Tonnage</label>
                            <input type="text" class="form-control" asp-for="@Model.TotalTonnage">
                        </div>
                    </div>
                    <div class="col-md-6 ">

                    </div>
                </div>

            </div>
            <div class="box-footer">
                <div class="row">
                    <div class="col-md-11 ">
                        <a class="btn btn-default pull-right nav-btn" href="@Url.Action("ConvertToEnquiry","EnquiryOpportunity",new {leadId="",BusinesSeg=Model.BusinessSegment })" style="padding-left:35px;padding-right:35px">Cancel</a>
                        <button class="btn btn-success pull-right margin-r-5 nav-btn" id="btnAddProductSumbit" style="padding-left:35px;padding-right:35px">Save</button>

                    </div>
                </div>
            </div>
        </div>



    </form>




</section>


