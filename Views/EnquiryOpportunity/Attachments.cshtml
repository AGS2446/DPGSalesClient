@model DPGSalesClient.Models.AttachmentsModel

@section styles{
    <link href="~/css/Index.css" rel="stylesheet" />
}
    @{ var docTypeText = new Dictionary<string, string>
            {
        { "BidNoBid", "Bid / No-Bid Analysis " },
        { "PreBidQueries", "Pre-Bid Queries & Resolutions" },
        { "ContractsFinance", "Inputs from Contracts & Finance " },
        { "ManagementApproval", "Management Approval " },
        { "OtherDocuments", "Other Documents" },
        { "Opportunity", "Opportunity" }
    }; }


    <style>
        .btn-file {
            position: relative;
            overflow: hidden;
        }

            .btn-file input[type=file] {
                position: absolute;
                top: 0;
                right: 0;
                min-width: 100%;
                min-height: 100%;
                font-size: 100px;
                text-align: right;
                filter: alpha(opacity=0);
                opacity: 0;
                outline: none;
                background: white;
                cursor: inherit;
                display: block;
            }

        /* Mandatory badge on dropdown option row */
        .doc-type-mandatory-hint {
            font-size: 11px;
            color: #c0392b;
            margin-top: 3px;
            display: none;
        }

        #ddlDocumentType.is-invalid {
            border-color: #e74c3c;
            box-shadow: 0 0 0 2px rgba(231,76,60,.18);
        }
    </style>

    <section class="content-header">
        <h1>
            Cost Sheet Documents
        </h1>
    </section>
    <section class="content">

        <form asp-action="Attachments" asp-controller="EnquiryOpportunity" method="post">

            <input type="hidden" value="@Model.PendingUploadFiles" asp-for="@Model.PendingUploadFiles" id="datFile" />
            <input type="hidden" value="@Model.ActivityId" asp-for="@Model.ActivityId" />
            <input type="hidden" id="hidDocumentType" asp-for="@Model.DocumentType" />
            <input type="hidden" id="isDirect" asp-for="@Model.isDirect" />

            <div class="box box-warning" style="padding-right:50px">
                <div class="box-header with-border">
                    <h3 class="box-title text-warning">Uploaded Documents</h3>
                </div>
                <div class="box-body">

                    <div class="row">
                        <div class="col-md-8">
                            @if (Model.UploadedFiles != null && Model.UploadedFiles.Count > 0)
                            {
                <table id="tblAttachments" class="table table-hover">
                    <thead>
                        <tr>
                            <th></th>
                            <th>Name</th>
                            <th>Document Type</th>
                            <th>User ID</th>
                            <th>User Name</th>
                            <th>Created On</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var file in Model.UploadedFiles)
                        {
        <tr>
            @*<td><a href="@file.FileUrl" target="_blank"><i class="fa fa-download"></i></a></td>*@
            <td><a href="@Url.Action("DownloadFile","EnquiryOpportunity",
                new { filePath = @file.FileUrl })" target="_blank">
                    <i class="fa fa-download"></i>
                </a></td>
            <td>@file.Name</td>
            <td>
                @(
        !string.IsNullOrEmpty(file.DocumentType) && docTypeText.ContainsKey(file.DocumentType)
        ? docTypeText[file.DocumentType]
        : "-"
     )
            </td>
            <td>@file.UserID</td>
            <td>@file.UserName</td>
            <td>@String.Format("{0:dd/MM/yyyy HH:mm:ss}", file.CreatedOn)</td>
            <th><a class="nav-btn text-danger" href="@Url.Action("DeleteAttachment", "EnquiryOpportunity", new { Id = file.AttachmentId, activityID = Model.ActivityId })" style="padding-right:15px;"><i class="fa fa-trash" style="font-size:18px;font-weight:500;"></i></a></th>
        </tr>}
                    </tbody>
                </table> }
            else
            {
<span style="margin-left: 15px; top: -10px; position: relative;">No documents uploaded yet.</span>}
                        </div>
                    </div>

                    <h4 class="box-title text-green">New Documents</h4>

                    @if (!Model.isDirect)
                    {

                    
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label for="ddlDocumentType">Document Type <span class="text-danger">*</span></label>
                                <select id="ddlDocumentType" class="form-control">
                                    <option value="">-- Select Document Type --</option>
                                    <option value="BidNoBid" data-mandatory="1">Bid / No-Bid Analysis &nbsp;[Mandatory]</option>
                                    <option value="PreBidQueries" data-mandatory="0">Pre-Bid Queries &amp; Resolutions</option>
                                    <option value="ContractsFinance" data-mandatory="0">Inputs from Contracts &amp; Finance &nbsp;</option>
                                    <option value="ManagementApproval" data-mandatory="0">Management Approval &nbsp;</option>
                                    <option value="OtherDocuments" data-mandatory="0">Other Documents</option>
                                    @*<option value="Opportunity" data-mandatory="0">Opportunity</option>*@
                                </select>
                                <div class="doc-type-mandatory-hint" id="mandatoryHint">
                                    <i class="fa fa-exclamation-circle"></i> This is a mandatory document type.
                                </div>
                            </div>
                        </div>
                    </div>
                    }

                    <div class="row">
                        <div class="col-md-3">
                            <div class="form-group">
                                <label for="exampleInputFile">File input</label><br />
                                <input type="file" id="cpFileupload">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <a id="btnAdd" class="btn btn-warning margin">Add File</a>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-4 ">
                            <ul id="uploadFileList" style="padding: 0;"></ul>
                        </div>
                    </div>

                </div>
                <div class="box-footer">
                    <div class="row">
                        <div class="col-md-11 ">
                            <button class="btn btn-success margin-r-5" style="padding-left:35px;padding-right:35px" type="submit">Upload</button>
                            <a class="btn btn-default" href="@Url.Action("Index","EnquiryOpportunity")" style="padding-left:35px;padding-right:35px">Cancel</a>
                        </div>
                    </div>
                </div>
            </div>

        </form>

        <!-- Modal -->

    </section>


    @section scripts{
        <script type="text/javascript" src="~/js/scripts/Attachments1.js"></script>
    }
