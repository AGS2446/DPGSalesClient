    }
    .bg-lr-Active>a{
        background: transparent !important;
        color: #444 !important;
       border-top: 0 !important;
       border-left-color: #FF5533 !important;
    }
     .bg-lo-Active>a{
        background: transparent !important;
        color: #444 !important;
       border-top: 0 !important;
       border-left-color: #FF7D33 !important;
    }


    .rupSymbol{
        color: #444;
        font-size:10px;
        font-weight: 400;
    }
     .lbl-Cat-Name{
        color: #444;
