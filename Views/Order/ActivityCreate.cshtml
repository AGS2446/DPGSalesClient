@model DPGSalesClient.Models.ContactPlanNewModel

@section styles{
    <link href="~/css/CreateEdit.css" rel="stylesheet" />
}

<section class="content-header">
    <h1>
        New Activity
    </h1>
   
</section>
<section class="content" >

    <form asp-action="ActivityCreate" asp-controller="Order" method="post" id="ActivityNewForm">

        <div class="box box-info">
            <div class="box-header with-border">
                <h3 class="box-title">Customer Info</h3>
            </div>
            <div class="box-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>CustomerID </label>
                            <input type="text" class="form-control" asp-for="@Model.CustomerID" readonly>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Name <span class="text-red">*</span></label>
                            <div class="input-group input-group-sm">
                                <input type="text" class="form-control" asp-for="@Model.Name" readonly>
                                <span class="input-group-btn ">
                                    <a id="btnCustomerSearch" class="btn btn-info btn-flat"><i class="fa fa-search"></i></a>@*href="@Url.Action("Customers", "ContactPlan")"*@
                                </span>
                            </div>
                        </div>

                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Contact Person <span class="text-red">*</span></label>
                            <input type="text" class="form-control" asp-for="@Model.ContactName">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Designation <span class="text-red">*</span></label>
                            <input type="text" class="form-control" asp-for="@Model.Designation">
                        </div>
                    </div>

                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>MobileNumber <span class="text-red">*</span></label>
                            <input type="text" class="form-control" asp-for="@Model.MobileNumber">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Email ID <span class="text-red">*</span></label>
                            <input type="text" class="form-control" asp-for="@Model.EmailID">
                        </div>
                    </div>

                </div>
            </div>

        </div>
        <div class="box box-success">
            <div class="box-header with-border">
                <h3 class="box-title">Activity Info</h3>
            </div>
            <div class="box-body">
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Visit Date <span class="text-red">*</span></label>

                            <div class="input-group date">
                                <div class="input-group-addon">
                                    <i class="fa fa-calendar"></i>
                                </div>
                                <input type="text" class="form-control pull-right" id="dtVisitOn" asp-for="@Model.VisitOn" placeholder="dd/mm/yyyy">
                            </div>

                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Objective of the Visit <span class="text-red">*</span></label>

                            @*@Html.DropDownList(@Model.ObjectiveofVisit, (@Model.ObjectiveOfVisitList as IEnumerable<SelectListItem>),new {@class= "form-control select2", @style = "width: 100%;" })*@
                            <select class="form-control select2" style="width: 100%;" asp-for="@Model.ObjectiveofVisit" asp-items="@(new SelectList(Model.ObjectiveOfVisitList,"Value","Text"))"></select>

                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Other Team Members </label>
                            <input type="text" class="form-control" asp-for="@Model.OtherTeamMembers">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>List of Discussion <span class="text-red">*</span></label>
                            <input type="text" class="form-control" asp-for="@Model.ListofDicsussion">
                        </div>
                    </div>

                </div>

                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Support Required<span class="text-red">*</span></label>
                            @*<input type="text" class="form-control" asp-for="@Model.SupportRequired">*@
                            <select class="form-control select2" style="width: 100%;" asp-for="@Model.SupportRequired" asp-items="@(new SelectList(Model.SupportRequiredList,"Value","Text"))"></select>
                        </div>
                    </div>
                    <div class="col-md-6 ">
                        <div class="form-group">
                            <label>DocumentID</label>
                            <input type="text" class="form-control" asp-for="@Model.DocumentID" readonly>

                        </div>
                    </div>
                </div>

                <div class="row ">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label>Remarks </label>

                            <textarea type="text" class="form-control" asp-for="@Model.Remarks" style="min-height:60px"></textarea>

                        </div>

                    </div>
                </div>
            </div>
            <div class="box-footer">
                <div class="row">
                    <div class="col-md-11 ">
                        <a class="btn btn-default pull-right nav-btn" href="@Url.Action("ActivityIndex","Order",new {  ordId =Model.DocumentID ,custname=Model.Name})" style="padding-left:35px;padding-right:35px">Cancel</a>
                        <button class="btn btn-success pull-right margin-r-5 nav-btn" style="padding-left:35px;padding-right:35px" type="submit">Save</button>

                    </div>
                </div>
            </div>
        </div>
    
    </form>


    <!-- Modal -->
    <div class="modal fade" id="activityCustomersModal" tabindex="-1" role="dialog" aria-labelledby="activityCustomersModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="activityCustomersModalLabel">Customers</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <ul id="ulCustomers" class="CustUl"></ul>

                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="button" id="btnCustSelect" class="btn btn-primary">Ok</button>
                </div>
            </div>
        </div>
    </div>

</section>


@section scripts{

   <script type="text/javascript" src="~/js/scripts/ActivityCreateEdit.js">
</script>
}