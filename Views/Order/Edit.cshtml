@model DPGSalesClient.Models.OrderNewModel

@section styles{
    <link href="~/css/CreateEdit.css" rel="stylesheet" />
}
<section class="content-header">
    <h1 class="pull-left">
        Edit Order
    </h1>
    <a class="btn nav-btn bg-green pull-right" id="btnEditProduct">Items</a>

</section>
<section class="content">
    <form asp-action="Edit" asp-controller="Order" id="ordEditForm">
        <input type="hidden" asp-for="@Model.OrderID" />
        <input type="hidden" asp-for="@Model.QuoteID" />
        <input type="hidden" asp-for="@Model.EnquiryID" />
        <input type="hidden" asp-for="@Model.LeadID" />
        <input type="hidden" asp-for="@Model.isDirect" />
        <div class="row">
            <div class="col-md-12">

                <div class="content">
                    <div class="box box-primary">
                        <div class="box-header with-border">
                            <h3 class="box-title">Location</h3>
                        </div>
                        <div class="box-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Division</label>
                                        <input type="text" class="form-control" asp-for="@Model.Division" readonly>
                                        @*<select class="form-control select2" style="width: 100%;" asp-for="@Model.Division" asp-items="@(new SelectList(Model.DivisionList,"Value","Text"))" readonly></select>*@
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Region<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.Region" asp-items="@(new SelectList(Model?.RegionList,"Value","Text"))"></select>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Branch<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.Branch" asp-items="@(new SelectList(Model?.BranchList,"Value","Text"))"></select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Sales Office</label>
                                        <input type="text" class="form-control" asp-for="@Model.SalesOffice" readonly>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Plant</label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.Plant" asp-items="@(new SelectList(Model?.PlantsList,"Value","Text"))"></select>
                                    </div>
                                </div>
                                <div class="col-md-6">

                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="box box-info">
                        <div class="box-header with-border">
                            <h3 class="box-title">Customer Details</h3>
                        </div>
                        <div class="box-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Customer Code<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.CustomerCode" readonly>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Customer Name<span class="text-red">*</span></label>
                                        <div class="input-group input-group-sm">
                                            <input type="text" class="form-control" asp-for="@Model.CustomerName" readonly>
                                            <span class="input-group-btn">
                                                <a href="@Url.Action("Customers","Order")" id="btnCustomerSearch" class="btn btn-info btn-flat" disable><i class="fa fa-search"></i></a>
                                            </span>
                                        </div>
                                    </div>

                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>City<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.City" >
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>State<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.State" >
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Phone Number<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.MobileNumber" >
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Pin Code<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.Pincode" >
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Contact Person<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.ContactPerson" >
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Customer Address<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.CustomerAddress" >
                                    </div>

                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Customer Segment<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.CustomerSegment" asp-items="@(new SelectList(Model?.CustomerSegmentList,"Value","Text"))"></select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Customer Sub Segment<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.CustomerSubSegment" asp-items="@(new SelectList(Model?.CustomerSubSegmentList,"Value","Text"))"></select>
                                    </div>

                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Customer Classification<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.CustomerClassification" asp-items="@(new SelectList(Model?.CustomerClassificationList,"Value","Text"))"></select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Customer Type<span class="text-red">*</span></label>
                                        <select class="form-control select2 @Model.CustomerType" style="width: 100%;" asp-for="@Model.CustomerType" asp-items="@(new SelectList(Model?.CustomerTypeList,"Value","Text"))"></select>
                                    </div>

                                </div>
                            </div>

                        </div>
                    </div>

                    <div class="box box-success">
                        <div class="box-header with-border">
                            <h3 class="box-title">Order Details</h3>
                        </div>
                        <div class="box-body">
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Quote No</label>
                                        <input type="text" class="form-control" asp-for="@Model.QuoteID" readonly />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Project Name<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.ProjectName">                                      
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>OrderType<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.OrderType" readonly />
                                        @*<select class="form-control select2" style="width: 100%;" asp-for="@Model.OrderType" asp-items="@(new SelectList(Model?.OrderTypeList,"Value","Text"))"></select>*@
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Total Item Value (In Lakhs)<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.TotalItemValue">
                                    </div>
                                </div>
                            </div>

                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Won/Loss<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.WonLossValue" asp-items="@(new SelectList(Model?.WonLossValueList,"Value","Text"))"></select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Reasons</label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.Reasons" asp-items="@(new SelectList(Model?.ReasonsList,"Value","Text"))"></select>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>PO No</label>
                                        <input type="text" class="form-control" asp-for="@Model.PONo"  />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>PO Date</label>
                                        <div class="input-group date">
                                            <div class="input-group-addon">
                                                <i class="fa fa-calendar"></i>
                                            </div>
                                            <input type="text" class="form-control pull-right" asp-for="@Model.PODate">
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Contract Value (In Lakhs) <span class="text-red">*</span></label>
                                        <div class="input-group input-group-sm">
                                            <input type="text" class="form-control" asp-for="@Model.ContractValue" readonly>
                                            <span class="input-group-btn">
                                                <a id="btnContractValue" class="btn btn-warning btn-flat"><i class="fa fa-edit"></i></a>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>TotalCost (In Lakhs)</label>
                                        <input type="text" class="form-control" asp-for="@Model.TotalCost">
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Business Segment<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.BusinessSegment" asp-items="@(new SelectList(Model?.BusinessSegmentList,"Value","Text"))"></select>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Assign To<span class="text-red">*</span></label>
                                        <input type="text" class="form-control" asp-for="@Model.AssignTo" readonly>
                                    </div>
                                </div>
                                @*<div class="col-md-6">
                                    <div class="form-group">
                                        <label>Document Created Date<span class="text-red">*</span></label>
                                        <div class="input-group date">
                                            <div class="input-group-addon">
                                                <i class="fa fa-calendar"></i>
                                            </div>
                                            <input type="text" class="form-control pull-right" asp-for="@Model.DocumentCreatedDate">
                                        </div>
                                    </div>
                                </div>*@
                            </div>
                            <div class="row">
                               
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Competitor Name</label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.CompName" asp-items="@(new SelectList(Model?.CompNameList,"Value","Text"))"></select>

                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Competitor Price (In Lakhs)</label>
                                        <input type="text" class="form-control" asp-for="@Model.CompititorPrice">
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Turn Over</label>
                                        <input type="text" class="form-control" asp-for="@Model.TurnOver" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Total Tonnage</label>
                                        <input type="text" class="form-control" asp-for="@Model.TotalTonnage"  />
                                    </div>
                                </div>                               
                            </div>
                            <div class="row">                                
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Gross Margin</label>
                                        <input type="text" class="form-control" asp-for="@Model.GrossMargin">
                                    </div>
                                </div>
                            </div>
                            <div class="row">
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Architect</label>
                                        <input type="text" class="form-control" asp-for="@Model.Architect" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Consultant</label>
                                        <input type="text" class="form-control" asp-for="@Model.Consultant">
                                    </div>
                                </div>
                            </div>

                        
                            <div class="row">
                               
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Classification 2</label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.Classification2" asp-items="@(new SelectList(Model?.Classification2List,"Value","Text"))" readonly></select>
                                    </div>
                                </div>
                            
                                <div class="col-md-6">
                                    <div class="form-group">
                                        <label>Classification 4<span class="text-red">*</span></label>
                                        <select class="form-control select2" style="width: 100%;" asp-for="@Model.Classification4" asp-items="@(new SelectList(Model?.Classification4List,"Value","Text"))" readonly></select>
                                    </div>

                                </div>
                            </div>

                         
                        </div>
                    </div>
                </div>

            </div>
            <!-- /.col -->

        </div>
        <!-- /.row -->
        <div class="row">
            <div class="col-md-11 ">
                <a class="btn btn-default pull-right nav-btn" href="@Url.Action("Details","Order",new {ordId=Model.OrderID,status="OPEN" })" style="padding-left:35px;padding-right:35px">Cancel</a>
                <button class="btn btn-success pull-right margin-r-5 nav-btn" type="submit" style="padding-left:35px;padding-right:35px">Save</button>
            </div>
        </div>
    </form>
    <!-- Modal -->
    <div class="modal fade" id="enqCustomersModal" tabindex="-1" role="dialog" aria-labelledby="enqCustomersModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <h5 class="modal-title" id="activityCustomersModalLabel" style="font-weight: 800;color: #00BCD4;">Customers</h5>

                </div>
                <div class="modal-body" style="height:400px;overflow-y:auto">
                    <ul id="ulCustomers" class="CustUl"></ul>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-dismiss="modal">Cancel</button>
                    <button type="button" id="btnCustSelect" class="btn btn-primary">Ok</button>
                </div>
            </div>
        </div>
    </div>
    <div class="modal fade" id="contractModal" tabindex="-1" role="dialog" aria-labelledby="contractModalLabel" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header">
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                    <h5 class="modal-title" id="contractModalLabel" style="font-weight: 800;color: #00BCD4;">Contract Value</h5>
                </div>
                <div class="modal-body">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Contract Value <small>In Lakhs</small><span class="text-red">*</span></label>
                            <input type="text" class="form-control" id="txtContractValue">
                        </div>
                    </div>
                </div>
                <div class="modal-footer" style="text-align:center">
                    <button type="button" id="btnContractValueSave" style="width:80px" class="btn btn-primary nav-btn">Save</button>
                    <button type="button" class="btn btn-secondary" style="width:80px" data-dismiss="modal">Cancel</button>
                </div>
            </div>
        </div>
    </div>

</section>

@section scripts{
    <script type="text/javascript" src="~/js/scripts/Order/Edit.js">
    </script>
}